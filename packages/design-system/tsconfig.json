{
  "extends": "../config/tsconfig/base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "noEmit": false,
    "paths": {
      "@speckit/design-system": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
